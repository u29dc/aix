{
	"manifest_version": 3,
	"name": "AI Chat Exporter",
	"version": "1.0.0",
	"description": "Export AI chat conversations to clean markdown files with a single click.",
	"icons": {
		"16": "assets/icon-16.png",
		"32": "assets/icon-32.png",
		"128": "assets/icon-128.png"
	},
	"action": {
		"default_title": "AI Chat Exporter"
	},
	"content_scripts": [
		{
			"matches": ["https://claude.ai/*"],
			"js": ["contentScript.js"],
			"run_at": "document_idle"
		}
	]
}
